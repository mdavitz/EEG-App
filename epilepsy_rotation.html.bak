      <!-- Inpatient Rotation Info Box -->
      <div class="info-box" id="fellows-inpatient">
        <h2>Inpatient Rotation</h2>
        <!-- Inpatient Rotation Table -->
        <table class="custom-table">
          <thead>
            <tr>
              <th>Location</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>MSH</td>
